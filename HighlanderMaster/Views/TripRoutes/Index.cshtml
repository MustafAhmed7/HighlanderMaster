@model IEnumerable<HighlanderMaster.Models.TripRoute>
@{
    ViewData["Title"] = "Маршрути";
}
<div class="p-5 mb-4 bg-light rounded-3 text-center">
    <div class="container py-3">
        <h1 class="display-5 fw-bold">🏔 Всички Маршрути</h1>
        <p class="lead">Разгледай всички налични маршрути и се запиши за следващото си приключение.</p>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success btn-lg">+ Добави Маршрут</a>
        }
    </div>
</div>
<div class="container mb-5">
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(item.MainPicURL))
                    {
                        <img src="@item.MainPicURL" class="card-img-top" style="height:200px; object-fit:cover;" alt="@item.Name" />
                    }
                    else
                    {
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height:200px;">
                            <span style="font-size:3rem;">🏔</span>
                        </div>
                    }
                    <div class="card-body">
                        <span class="badge bg-success mb-2">@item.Status</span>
                        <h5 class="card-title fw-bold">@item.Name</h5>
                        <p class="card-text text-muted">
                            @(item.Description?.Length > 80 ? item.Description.Substring(0, 80) + "..." : item.Description ?? "")
                        </p>
                        <div class="d-flex gap-3 text-muted small mb-2">
                            <span>📍 @item.StartingPoint → @item.EndPoint</span>
                        </div>
                        <div class="d-flex gap-3 text-muted small">
                            <span>📏 @item.LenghtKm км</span>
                            <span>👥 @item.CurrentParticipants/@item.MaxCountPeople</span>
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <span class="text-muted small">📅 @item.StartTime.ToString("dd MMM yyyy")</span>
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-success btn-sm">Детайли</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">✏️</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">🗑</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
